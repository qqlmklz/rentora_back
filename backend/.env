# Server
PORT=8080
GIN_MODE=debug

# CORS (comma-separated origins, use * for all)
CORS_ORIGINS=*

# Database (required for auth)
# Замените user:password на своего пользователя и пароль PostgreSQL.
# Пример для локального postgres: postgres://postgres:postgres@localhost:5432/rentora
DATABASE_URL=postgres://postgres:121248@localhost:5432/rentora_db

# JWT (required for login / auth)
JWT_SECRET=your-secret-key-change-in-production
